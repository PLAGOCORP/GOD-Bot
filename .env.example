# ========== God Bot — botgod.pro ==========
NODE_ENV=production

DISCORD_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
GUILD_ID=
OWNER_IDS=
PREFIX=g!

# Dominio público (tu compra)
DOMAIN=botgod.pro
SITE_NAME=BotGod

# URL pública HTTPS (sin slash final)
DASHBOARD_URL=https://botgod.pro
DASHBOARD_PORT=3847
# Cookies secure en HTTPS (auto si DASHBOARD_URL es https)
COOKIE_SECURE=true
SESSION_SECRET=genera-un-secreto-largo-aleatorio-aqui

# IA opcional
XAI_API_KEY=
XAI_MODEL=grok-4.5

# ========== Firebase Godbot (godbot-d5aa2) ==========
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=godbot-d5aa2.firebaseapp.com
FIREBASE_PROJECT_ID=godbot-d5aa2
FIREBASE_STORAGE_BUCKET=godbot-d5aa2.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=135271463932
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=G-02ZJFJD3TN
FIREBASE_PROJECT_NUMBER=135271463932
SUPPORT_EMAIL=plago1806@gmail.com
# Service account (Admin SDK) — genera en Firebase → Service accounts
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/godbot-sa.json
# O pega el JSON en una sola línea:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ========== Música (YouTube) ==========
# YouTube bloquea (HTTP 429) las peticiones de streaming desde IPs de datacenter
# (Render, Railway, AWS, etc.) si no van autenticadas. Para arreglarlo:
# 1. Inicia sesión en youtube.com en tu navegador
# 2. Instala la extensión "Get cookies.txt" (Chrome/Firefox) o copia el header
#    Cookie desde DevTools → Network → cualquier petición a youtube.com
# 3. Pega el valor completo aquí (una sola línea, formato "nombre=valor; nombre2=valor2")
YOUTUBE_COOKIE=

LOG_LEVEL=info
