# ========== God Bot — botgod.pro ==========
NODE_ENV=production

DISCORD_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
GUILD_ID=
OWNER_IDS=
PREFIX=g!

# Dominio público (tu compra)
DOMAIN=botgod.pro
SITE_NAME=BotGod

# Landing en Firebase; dashboard Express en subdominio Render
DASHBOARD_URL=https://panel.botgod.pro
API_PUBLIC_URL=https://panel.botgod.pro
DASHBOARD_PORT=3847
# Render inyecta PORT; local usa DASHBOARD_PORT
COOKIE_SECURE=true
SESSION_SECRET=genera-un-secreto-largo-aleatorio-aqui
KEEPALIVE_INTERVAL_MS=240000

# IA opcional
XAI_API_KEY=
XAI_MODEL=grok-4.5

# ========== Firebase Godbot (godbot-d5aa2) ==========
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=godbot-d5aa2.firebaseapp.com
FIREBASE_PROJECT_ID=godbot-d5aa2
FIREBASE_STORAGE_BUCKET=godbot-d5aa2.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=135271463932
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=G-02ZJFJD3TN
FIREBASE_PROJECT_NUMBER=135271463932
SUPPORT_EMAIL=plago1806@gmail.com
# Service account (Admin SDK) — genera en Firebase → Service accounts
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/godbot-sa.json
# O pega el JSON en una sola línea:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ========== Música (Lavalink) ==========
# La música de Discord requiere UDP, que algunos hosts (Railway) no soportan.
# Por eso el audio se delega a un servidor Lavalink alojado en un host con UDP.
# Ver LAVALINK_SETUP.md para desplegarlo. Datos de conexión al nodo:
LAVALINK_HOST=
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# (Opcional) cookie de YouTube, solo si tu Lavalink usa el plugin youtube-source
# con soporte de cookies. Formato "nombre=valor; nombre2=valor2".
YOUTUBE_COOKIE=

LOG_LEVEL=info
