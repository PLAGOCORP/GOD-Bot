<aside id="dash-sidebar" class="dash-sidebar">
  <div class="dash-sidebar-brand">
    <a href="/servers">
      <span class="logo-mark">⚡</span>
      <span>Bot<span style="color:#fbbf24">God</span></span>
      <span style="font-size:0.7rem;color:#64748b;font-weight:500">.pro</span>
    </a>
  </div>

  <div class="dash-guild-chip">
    <a href="/servers">
      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <span class="truncate">Todos los servidores</span>
    </a>
  </div>

  <nav class="dash-nav">
    <div class="dash-nav-section">Principal</div>
    <a href="/servers/<%= guild.id %>/panel/dashboard" class="dash-nav-link <%= current === 'dashboard' ? 'active' : '' %>">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
      Dashboard
    </a>
    <a href="/servers/<%= guild.id %>/panel/general" class="dash-nav-link <%= current === 'general' ? 'active' : '' %>">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      General
    </a>
    <a href="/servers/<%= guild.id %>/panel/channels" class="dash-nav-link <%= current === 'channels' ? 'active' : '' %>">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/></svg>
      Canales
    </a>
    <a href="/servers/<%= guild.id %>/panel/roles" class="dash-nav-link <%= current === 'roles' ? 'active' : '' %>">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
      Roles
    </a>

    <div class="dash-nav-section">Módulos</div>
    <% const mods = [
      { id:'welcome', label:'Bienvenida', path:'M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z' },
      { id:'moderation', label:'Moderación', path:'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
      { id:'logging', label:'Logs', path:'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
      { id:'tickets', label:'Tickets', path:'M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z' },
      { id:'leveling', label:'Niveles', path:'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
      { id:'economy', label:'Economía', path:'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
      { id:'giveaways', label:'Sorteos', path:'M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7' },
      { id:'starboard', label:'Starboard', path:'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z' },
      { id:'music', label:'Música', path:'M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3' },
      { id:'automod', label:'AutoMod', path:'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z' },
      { id:'security', label:'Seguridad', path:'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
    ]; %>
    <% mods.forEach(function(m) { %>
      <a href="/servers/<%= guild.id %>/panel/<%= m.id %>" class="dash-nav-link <%= current === m.id ? 'active' : '' %>">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= m.path %>"/></svg>
        <%= m.label %>
      </a>
    <% }) %>

    <div class="dash-nav-section">Admin</div>
    <a href="/servers/<%= guild.id %>/panel/members" class="dash-nav-link <%= current === 'members' ? 'active' : '' %>">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      Miembros
    </a>
    <a href="/servers/<%= guild.id %>/panel/audit" class="dash-nav-link <%= current === 'audit' ? 'active' : '' %>">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Auditoría
    </a>

    <div class="dash-nav-section">Extras</div>
    <% const extras = [
      { id:'birthdays', label:'Cumpleaños' },
      { id:'tempvc', label:'Temp VC' },
      { id:'stats', label:'Stats' },
      { id:'tags', label:'Tags' },
      { id:'confessions', label:'Confesiones' },
      { id:'suggestions', label:'Sugerencias' },
      { id:'invites', label:'Invites' },
    ]; %>
    <% extras.forEach(function(m) { %>
      <a href="/servers/<%= guild.id %>/panel/<%= m.id %>" class="dash-nav-link <%= current === m.id ? 'active' : '' %>">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <%= m.label %>
      </a>
    <% }) %>
  </nav>

  <div class="dash-sidebar-footer">
    <% if (typeof user !== 'undefined' && user) { %>
      <div class="dash-user-row mb-2">
        <% if (user.avatar) { %>
          <img class="dash-user-avatar" src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=64" alt=""/>
        <% } else { %>
          <div class="dash-user-avatar-fallback"><%= (user.global_name || user.username || '?').charAt(0) %></div>
        <% } %>
        <div class="min-w-0 flex-1">
          <div class="text-sm font-semibold text-slate-200 truncate"><%= user.global_name || user.username %></div>
          <div class="text-xs text-slate-500 truncate">@<%= user.username %></div>
        </div>
      </div>
    <% } %>
    <div class="flex items-center justify-between text-xs text-slate-500">
      <div class="flex items-center gap-1.5">
        <span class="dash-status-dot"></span>
        <span>v<%= typeof botVersion !== 'undefined' ? botVersion : '3.1.0' %></span>
      </div>
      <a href="/logout" class="text-red-400/80 hover:text-red-400 transition">Salir</a>
    </div>
  </div>
</aside>