<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>BotGod — El bot Discord todo-en-uno | botgod.pro</title>
  <meta name="description" content="God Bot: moderación, tickets, niveles, música, IA y dashboard. Self-hosted en botgod.pro"/>
  <meta property="og:title" content="BotGod — botgod.pro"/>
  <meta property="og:description" content="<%= bot.description %>"/>
  <meta property="og:url" content="<%= site.url %>"/>
  <meta property="og:type" content="website"/>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>"/>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen">
  <%- include('partials/nav') %>

  <header class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-amber-500/10 via-purple-900/20 to-slate-950 pointer-events-none"></div>
    <div class="max-w-6xl mx-auto px-6 pt-20 pb-16 relative text-center">
      <p class="text-amber-400/90 text-sm font-semibold tracking-widest uppercase mb-4">botgod.pro</p>
      <h1 class="text-5xl sm:text-7xl font-black mb-6">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-200 to-amber-500">God</span>
        <span class="text-white"> Bot</span>
      </h1>
      <p class="text-xl text-slate-300 max-w-2xl mx-auto mb-10">
        El bot Discord todo-en-uno. Moderación nivel Carl-bot, tickets, niveles, música real, NQN, IA y dashboard web.
        Sin paywalls. En español.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="<%= inviteUrl %>" target="_blank" rel="noopener"
           class="bg-amber-400 hover:bg-amber-300 text-slate-950 font-bold px-8 py-3.5 rounded-xl transition shadow-lg shadow-amber-500/20">
          Invitar a Discord
        </a>
        <a href="/login"
           class="bg-indigo-600 hover:bg-indigo-500 text-white font-semibold px-8 py-3.5 rounded-xl transition">
          Abrir Dashboard
        </a>
        <a href="/features"
           class="border border-slate-700 hover:border-amber-500/50 text-slate-200 font-semibold px-8 py-3.5 rounded-xl transition">
          Ver features
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-16 max-w-3xl mx-auto">
        <div class="bg-slate-900/80 border border-slate-800 rounded-2xl p-5">
          <div class="text-2xl font-bold text-amber-400"><%= client.ready ? client.guilds : '—' %></div>
          <div class="text-slate-500 text-sm mt-1">Servidores</div>
        </div>
        <div class="bg-slate-900/80 border border-slate-800 rounded-2xl p-5">
          <div class="text-2xl font-bold text-amber-400"><%= client.ready ? client.users.toLocaleString('es-ES') : '—' %></div>
          <div class="text-slate-500 text-sm mt-1">Usuarios</div>
        </div>
        <div class="bg-slate-900/80 border border-slate-800 rounded-2xl p-5">
          <div class="text-2xl font-bold text-amber-400"><%= client.ready ? client.ping + 'ms' : '—' %></div>
          <div class="text-slate-500 text-sm mt-1">Ping</div>
        </div>
        <div class="bg-slate-900/80 border border-slate-800 rounded-2xl p-5">
          <div class="text-2xl font-bold text-amber-400">v<%= bot.version %></div>
          <div class="text-slate-500 text-sm mt-1">Versión</div>
        </div>
      </div>
    </div>
  </header>

  <section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-3xl font-bold text-center mb-12">Todo lo que necesitas. Un solo bot.</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% const cards = [
        { e: '🛡️', t: 'Moderación', d: 'Ban, warn, purge, automod con escalation, anti-raid y anti-nuke.' },
        { e: '🎫', t: 'Tickets', d: 'Panel, claim, transcript HTML y valoración CSAT.' },
        { e: '📈', t: 'Niveles', d: 'XP texto y voz, recompensas, no-XP channels, rank cards.' },
        { e: '🎵', t: 'Música', d: 'Audio real en voice con cola, skip, loop y volumen.' },
        { e: '😀', t: 'NQN Emotes', d: 'Usa emojis de otros servers con :nombre: sin Nitro.' },
        { e: '🌐', t: 'Dashboard', d: 'Gestiona módulos y roles desde botgod.pro con Discord login.' },
      ]; cards.forEach(function(c) { %>
        <div class="bg-slate-900 border border-slate-800 hover:border-amber-500/30 rounded-2xl p-6 transition">
          <div class="text-3xl mb-3"><%= c.e %></div>
          <h3 class="font-semibold text-lg mb-2"><%= c.t %></h3>
          <p class="text-slate-400 text-sm leading-relaxed"><%= c.d %></p>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 py-12 text-center">
    <div class="bg-gradient-to-r from-indigo-900/40 to-amber-900/20 border border-slate-800 rounded-3xl p-10">
      <h2 class="text-2xl font-bold mb-3">¿Listo para dominar tu servidor?</h2>
      <p class="text-slate-400 mb-6">Invita a God y configura todo con <code class="text-amber-400">/god setup</code></p>
      <a href="<%= inviteUrl %>" target="_blank" rel="noopener"
         class="inline-block bg-amber-400 hover:bg-amber-300 text-slate-950 font-bold px-8 py-3 rounded-xl transition">
        Añadir a Discord
      </a>
    </div>
  </section>

  <%- include('partials/footer') %>
</body>
</html>
