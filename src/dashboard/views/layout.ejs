<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title><%= title %> — BotGod</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            dark: { 50:'#f8fafc',100:'#f1f5f9',200:'#e2e8f0',300:'#cbd5e1',400:'#94a3b8',500:'#64748b',600:'#475569',700:'#334155',800:'#1e293b',850:'#172033',900:'#0f172a',950:'#020617' }
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/public/css/dashboard.css"/>
</head>
<body class="dashboard-body min-h-screen" data-guild-id="<%= guild.id %>">
  <div id="dash-bg"></div>
  <canvas id="dash-stars"></canvas>
  <div id="dash-overlay" class="dash-overlay"></div>

  <div class="dash-shell flex min-h-screen">
    <%- include('partials/sidebar', { guild, current: section, user, botVersion, notifications: typeof notifications !== 'undefined' ? notifications : { tickets: 0, confessions: 0, suggestions: 0, total: 0 } }) %>

    <div class="dash-main flex-1 flex flex-col">
      <header class="dash-header">
        <div class="flex items-center gap-3">
          <button id="menuToggle" type="button" class="lg:hidden text-slate-400 hover:text-amber-400 transition p-1" aria-label="Menú">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <div>
            <div class="dash-header-title"><%= title %></div>
            <div class="dash-header-sub">Panel de administración</div>
          </div>
        </div>
        <div class="dash-guild-badge">
          <span class="text-sm font-medium text-slate-300 hidden sm:inline max-w-[140px] truncate"><%= guild.name %></span>
          <% if (guild.icon) { %>
            <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png?size=64" alt=""/>
          <% } else { %>
            <div class="guild-icon-fallback"><%= guild.name.charAt(0) %></div>
          <% } %>
        </div>
      </header>

      <main class="dash-content">
        <%- body %>
      </main>
    </div>
  </div>

  <script src="/public/js/dashboard.js"></script>
  <script>
    async function saveSettings(url, data) {
      try {
        const res = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const json = await res.json();
        if (json.ok) showToast(json.message || 'Guardado correctamente');
        else showToast(json.error || 'Error al guardar', 'error');
      } catch (e) {
        showToast('Error de conexión', 'error');
      }
    }
  </script>
</body>
</html>