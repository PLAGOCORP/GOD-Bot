<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Servidores — BotGod</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚡</text></svg>"/>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/public/css/dashboard.css"/>
</head>
<body class="dashboard-body servers-page">
  <div id="dash-bg"></div>
  <canvas id="dash-stars"></canvas>

  <header class="servers-topbar">
    <a href="/" class="servers-brand">
      <span class="logo-mark">⚡</span>
      <span>Bot<span style="color:#fbbf24">God</span></span>
      <span style="font-size:0.7rem;color:#64748b;font-weight:500">.pro</span>
    </a>
    <div class="servers-user-chip">
      <% if (user.avatar) { %>
        <img class="dash-user-avatar" src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=64" alt=""/>
      <% } else { %>
        <div class="dash-user-avatar-fallback"><%= (user.global_name || user.username || '?').charAt(0) %></div>
      <% } %>
      <div class="hidden sm:block min-w-0">
        <div class="text-sm font-semibold text-slate-200 truncate max-w-[120px]"><%= user.global_name || user.username %></div>
        <div class="text-xs text-slate-500">Administrador</div>
      </div>
      <a href="/logout" class="text-xs text-red-400/80 hover:text-red-400 transition ml-1 sm:ml-2">Salir</a>
    </div>
  </header>

  <main class="relative z-10 flex-1 max-w-4xl w-full mx-auto px-4 sm:px-6 py-10 sm:py-14">
    <div class="servers-hero">
      <div class="relative z-10 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
        <div>
          <p class="text-amber-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Dashboard</p>
          <h1 class="text-3xl sm:text-4xl font-black text-white mb-2">Tus servidores</h1>
          <p class="text-slate-500 text-sm max-w-md">Elige un servidor donde tengas permisos de administrador y God Bot esté instalado.</p>
        </div>
        <div class="dash-stat-card stat-amber" style="padding:1rem 1.25rem;min-width:8rem">
          <div class="text-slate-500 text-xs font-semibold uppercase tracking-wide">Disponibles</div>
          <div class="text-3xl font-black text-amber-400" id="server-count"><%= guilds.length %></div>
        </div>
      </div>
    </div>

    <% if (!guilds.length) { %>
      <div class="servers-empty">
        <div class="text-5xl mb-4 opacity-80">🔍</div>
        <h3 class="text-xl font-bold text-white mb-2">No hay servidores</h3>
        <p class="text-slate-500 mb-8 max-w-sm mx-auto text-sm">Invita a God Bot a tu servidor y asegúrate de tener el permiso <strong class="text-slate-400">Administrator</strong>.</p>
        <a href="<%= inviteUrl || '#' %>" target="_blank" rel="noopener" class="dash-btn-primary">
          <span>⚡</span> Invitar a Discord
        </a>
      </div>
    <% } else { %>
      <div class="servers-search-wrap">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input type="search" id="serverSearch" class="servers-search" placeholder="Buscar servidor..." autocomplete="off"/>
      </div>

      <div class="grid gap-3 sm:grid-cols-2" id="serverGrid">
        <% guilds.forEach(function(g) { %>
          <a href="/servers/<%= g.id %>"
             class="server-pick-card"
             data-name="<%= g.name.toLowerCase() %>">
            <% if (g.icon) { %>
              <img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.png?size=128" alt="" class="server-pick-icon"/>
            <% } else { %>
              <div class="server-pick-icon-fallback"><%= g.name.charAt(0) %></div>
            <% } %>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 mb-0.5">
                <span class="font-bold text-white truncate"><%= g.name %></span>
                <span class="server-pick-badge shrink-0">Admin</span>
              </div>
              <div class="text-slate-600 text-xs font-mono truncate"><%= g.id %></div>
            </div>
            <svg class="server-pick-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        <% }) %>
      </div>

      <p id="noResults" class="hidden text-center text-slate-500 text-sm py-8">Ningún servidor coincide con tu búsqueda.</p>
    <% } %>
  </main>

  <footer class="servers-footer relative z-10">
    <span class="text-amber-400/50 font-semibold">botgod.pro</span>
    <div class="flex gap-4">
      <a href="https://botgod.pro" target="_blank" rel="noopener">Inicio</a>
      <a href="/privacy">Privacidad</a>
      <a href="/terms">Términos</a>
    </div>
  </footer>

  <script src="/public/js/dashboard.js"></script>
  <% if (guilds.length) { %>
  <script>
    (function () {
      const input = document.getElementById('serverSearch');
      const cards = document.querySelectorAll('.server-pick-card');
      const noResults = document.getElementById('noResults');
      const counter = document.getElementById('server-count');
      if (!input) return;
      input.addEventListener('input', function () {
        const q = input.value.trim().toLowerCase();
        let visible = 0;
        cards.forEach(function (card) {
          const match = !q || (card.dataset.name || '').includes(q);
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        if (noResults) noResults.classList.toggle('hidden', visible > 0);
        if (counter) counter.textContent = visible;
      });
    })();
  </script>
  <% } %>
</body>
</html>