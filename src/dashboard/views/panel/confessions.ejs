<div class="max-w-3xl space-y-6">
  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-xl font-semibold mb-4">Confesiones</h2>
    <form id="confessionsForm" class="space-y-4">
      <label class="flex items-center gap-3">
        <input type="checkbox" name="confessions_enabled" <%= modules.find(m=>m.name==='confessions')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="font-medium">Activar Confesiones</span>
      </label>

      <div class="grid sm:grid-cols-2 gap-4 mt-4">
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Canal Confesiones</label>
          <%- channelSelect('confessionChannel', settings.confessionChannel) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Canal Revisión</label>
          <%- channelSelect('confessionReviewChannel', settings.confessionReviewChannel) %>
        </div>
      </div>

      <button type="submit" class="mt-4 bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2 rounded-lg">Guardar</button>
    </form>
  </div>
</div>

<script>
document.getElementById('confessionsForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    confessionChannel: fd.get('confessionChannel') || null,
    confessionReviewChannel: fd.get('confessionReviewChannel') || null,
  });
  const mod = fd.get('confessions_enabled') === 'on';
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { confessions: mod } });
});
</script>