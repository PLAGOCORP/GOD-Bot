<div class="space-y-6 max-w-4xl">
  <div class="dash-hero">
    <div class="relative z-10">
      <p class="text-slate-400 text-xs font-bold tracking-[0.2em] uppercase mb-2">Registros</p>
      <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">📝 Logs</h1>
      <p class="text-slate-500 text-sm">Canales donde el bot registra eventos del servidor.</p>
    </div>
  </div>

  <div class="dash-card p-6">
    <form id="loggingForm" class="space-y-5">
      <label class="flex items-center gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 cursor-pointer">
        <input type="checkbox" name="logging_enabled" <%= modules.find(m=>m.name==='logging')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <div>
          <span class="font-semibold text-slate-200">Activar Logging</span>
          <p class="text-xs text-slate-600 mt-0.5">Joins, mensajes eliminados, cambios de canal, etc.</p>
        </div>
      </label>

      <div class="grid sm:grid-cols-2 gap-4">
        <div><label class="block text-xs text-slate-500 mb-1.5">Moderación</label><%- channelSelect('logMod', settings.logChannels?.mod) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Mensajes</label><%- channelSelect('logMessage', settings.logChannels?.message) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Miembros</label><%- channelSelect('logMember', settings.logChannels?.member) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Servidor</label><%- channelSelect('logServer', settings.logChannels?.server) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Tickets</label><%- channelSelect('logTicket', settings.logChannels?.ticket) %></div>
      </div>

      <button type="submit" class="dash-btn-primary">Guardar</button>
    </form>
  </div>
</div>

<script>
document.getElementById('loggingForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    logChannels: {
      mod: fd.get('logMod') || null,
      message: fd.get('logMessage') || null,
      member: fd.get('logMember') || null,
      server: fd.get('logServer') || null,
      ticket: fd.get('logTicket') || null,
    },
  });
  const mod = fd.get('logging_enabled') === 'on';
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { logging: mod } });
});
</script>