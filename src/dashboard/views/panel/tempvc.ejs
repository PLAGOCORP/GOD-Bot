<div class="space-y-6 max-w-4xl">
  <div class="dash-hero">
    <div class="relative z-10">
      <p class="text-cyan-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Voz</p>
      <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">🔊 Temp VC</h1>
      <p class="text-slate-500 text-sm">Salas de voz temporales creadas al unirse a un canal panel.</p>
    </div>
  </div>
  <div class="dash-card p-6">
    <form id="tempvcForm" class="space-y-5">
      <label class="flex items-center gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 cursor-pointer">
        <input type="checkbox" name="tempvc_enabled" <%= modules.find(m=>m.name==='tempvc')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="font-semibold text-slate-200">Activar Temp VC</span>
      </label>
      <div class="grid sm:grid-cols-2 gap-4">
        <div><label class="block text-xs text-slate-500 mb-1.5">Categoría</label><%- channelSelect('tempvcCategory', settings.tempvcCategory) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Canal panel</label><%- channelSelect('tempvcPanelChannel', settings.tempvcPanelChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Límite usuarios</label><input type="number" name="tempvcLimit" value="<%= settings.tempvcLimit || 3 %>" class="servers-search w-full sm:w-40" style="padding-left:1rem"/></div>
      </div>
      <button type="submit" class="dash-btn-primary">Guardar</button>
    </form>
  </div>
</div>
<script>
document.getElementById('tempvcForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    tempvcCategory: fd.get('tempvcCategory') || null,
    tempvcPanelChannel: fd.get('tempvcPanelChannel') || null,
    tempvcLimit: parseInt(fd.get('tempvcLimit'), 10) || 3,
  });
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { tempvc: fd.get('tempvc_enabled') === 'on' } });
});
</script>