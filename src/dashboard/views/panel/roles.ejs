<div class="max-w-3xl space-y-6">
  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-xl font-semibold mb-4">Roles del Servidor</h2>
    <form id="rolesForm" class="space-y-4">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Rol Moderador</label>
          <%- roleSelect('modRole', settings.modRole) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Rol Mute</label>
          <%- roleSelect('muteRole', settings.muteRole) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Rol Verificado</label>
          <%- roleSelect('verifiedRole', settings.verifiedRole) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Rol No Verificado</label>
          <%- roleSelect('unverifiedRole', settings.unverifiedRole) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Rol Cumpleaños</label>
          <%- roleSelect('birthdayRole', settings.birthdayRole) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Rol DJ (Música)</label>
          <%- roleSelect('musicDjRole', settings.musicDjRole) %>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Roles Staff (separados por coma, IDs)</label>
        <input type="text" name="staffRoles" value="<%= (settings.staffRoles || []).join(',') %>" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full" placeholder="id1,id2,id3"/>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Sticky Roles (separados por coma, IDs)</label>
        <input type="text" name="stickyRoleIds" value="<%= (settings.stickyRoleIds || []).join(',') %>" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full" placeholder="id1,id2,id3"/>
      </div>

      <button type="submit" class="mt-4 bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2 rounded-lg">Guardar roles</button>
    </form>
  </div>
</div>

<script>
document.getElementById('rolesForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    modRole: fd.get('modRole') || null,
    muteRole: fd.get('muteRole') || null,
    verifiedRole: fd.get('verifiedRole') || null,
    unverifiedRole: fd.get('unverifiedRole') || null,
    birthdayRole: fd.get('birthdayRole') || null,
    musicDjRole: fd.get('musicDjRole') || null,
    staffRoles: fd.get('staffRoles') ? fd.get('staffRoles').split(',').map(s => s.trim()).filter(Boolean) : [],
    stickyRoleIds: fd.get('stickyRoleIds') ? fd.get('stickyRoleIds').split(',').map(s => s.trim()).filter(Boolean) : [],
  });
});
</script>