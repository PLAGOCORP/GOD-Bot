<div class="space-y-6 max-w-4xl">
  <div class="dash-hero">
    <div class="relative z-10">
      <p class="text-violet-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Permisos</p>
      <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">🎭 Roles</h1>
      <p class="text-slate-500 text-sm">Roles especiales del bot: moderación, verificación, música y sticky roles.</p>
    </div>
  </div>

  <div class="dash-card p-6">
    <form id="rolesForm" class="space-y-5">
      <div class="grid sm:grid-cols-2 gap-4">
        <div><label class="block text-xs text-slate-500 mb-1.5">Rol moderador</label><%- roleSelect('modRole', settings.modRole) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Rol mute</label><%- roleSelect('muteRole', settings.muteRole) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Rol verificado</label><%- roleSelect('verifiedRole', settings.verifiedRole) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Rol no verificado</label><%- roleSelect('unverifiedRole', settings.unverifiedRole) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Rol cumpleaños</label><%- roleSelect('birthdayRole', settings.birthdayRole) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Rol DJ (música)</label><%- roleSelect('musicDjRole', settings.musicDjRole) %></div>
      </div>

      <div>
        <label class="block text-xs text-slate-500 mb-2">Sticky roles (se reasignan al volver)</label>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2 max-h-48 overflow-y-auto pr-1">
          <% roles.forEach(function(r) { %>
            <label class="flex items-center gap-2 py-2 px-3 rounded-lg bg-white/[0.02] border border-white/5 hover:border-violet-500/20 transition cursor-pointer">
              <input type="checkbox" name="sticky_<%= r.id %>" <%= (settings.stickyRoleIds || []).includes(r.id) ? 'checked' : '' %> class="rounded accent-amber-400"/>
              <span class="text-xs text-slate-300 truncate">@<%= r.name %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <p class="text-xs text-slate-600">Los roles staff se configuran en <a href="/servers/<%= guild.id %>/panel/moderation" class="text-amber-400/80 hover:text-amber-300">Moderación</a>.</p>
      <button type="submit" class="dash-btn-primary">Guardar roles</button>
    </form>
  </div>
</div>

<script>
document.getElementById('rolesForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const stickyRoleIds = [];
  <% roles.forEach(function(r) { %>
  if (fd.get('sticky_<%= r.id %>') === 'on') stickyRoleIds.push('<%= r.id %>');
  <% }) %>
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    modRole: fd.get('modRole') || null,
    muteRole: fd.get('muteRole') || null,
    verifiedRole: fd.get('verifiedRole') || null,
    unverifiedRole: fd.get('unverifiedRole') || null,
    birthdayRole: fd.get('birthdayRole') || null,
    musicDjRole: fd.get('musicDjRole') || null,
    stickyRoleIds,
  });
});
</script>