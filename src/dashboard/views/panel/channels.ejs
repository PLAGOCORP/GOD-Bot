<div class="space-y-6 max-w-5xl">
  <div class="dash-hero">
    <div class="relative z-10">
      <p class="text-cyan-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Mapa</p>
      <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">📢 Canales</h1>
      <p class="text-slate-500 text-sm">Vista centralizada de todos los canales configurados del servidor.</p>
    </div>
  </div>

  <div class="dash-card p-6">
    <form id="channelsForm" class="space-y-2">
      <p class="dash-section-title" style="margin-top:0;padding-top:0;border:0">Comunidad</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div><label class="block text-xs text-slate-500 mb-1.5">Bienvenida</label><%- channelSelect('welcomeChannel', settings.welcomeChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Despedida</label><%- channelSelect('leaveChannel', settings.leaveChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Nivel up</label><%- channelSelect('levelChannel', settings.levelChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Economía</label><%- channelSelect('economyChannel', settings.economyChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Verificación</label><%- channelSelect('verificationChannel', settings.verificationChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Starboard</label><%- channelSelect('starboardChannel', settings.starboardChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Confesiones</label><%- channelSelect('confessionChannel', settings.confessionChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Revisión confesiones</label><%- channelSelect('confessionReviewChannel', settings.confessionReviewChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Sugerencias</label><%- channelSelect('suggestionChannel', settings.suggestionChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Cumpleaños</label><%- channelSelect('birthdayChannel', settings.birthdayChannel) %></div>
      </div>

      <p class="dash-section-title">Tickets &amp; voz</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div><label class="block text-xs text-slate-500 mb-1.5">Categoría tickets</label><%- channelSelect('ticketCategory', settings.ticketCategory) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Log tickets</label><%- channelSelect('ticketLog', settings.ticketLog) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Panel Temp VC</label><%- channelSelect('tempvcPanelChannel', settings.tempvcPanelChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Categoría Temp VC</label><%- channelSelect('tempvcCategory', settings.tempvcCategory) %></div>
      </div>

      <p class="dash-section-title">Logs</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div><label class="block text-xs text-slate-500 mb-1.5">Mod</label><%- channelSelect('logChannels.mod', settings.logChannels?.mod) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Mensajes</label><%- channelSelect('logChannels.message', settings.logChannels?.message) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Miembros</label><%- channelSelect('logChannels.member', settings.logChannels?.member) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Servidor</label><%- channelSelect('logChannels.server', settings.logChannels?.server) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Tickets</label><%- channelSelect('logChannels.ticket', settings.logChannels?.ticket) %></div>
      </div>

      <p class="dash-section-title">Stats dinámicos <span class="text-slate-600 font-normal text-xs">(canales de voz)</span></p>
      <div class="grid sm:grid-cols-3 gap-4">
        <div><label class="block text-xs text-slate-500 mb-1.5">Voz — miembros</label><%- voiceChannelSelect('statsChannels.members', settings.statsChannels?.members) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Voz — en línea</label><%- voiceChannelSelect('statsChannels.online', settings.statsChannels?.online) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Voz — boosts</label><%- voiceChannelSelect('statsChannels.boosts', settings.statsChannels?.boosts) %></div>
      </div>

      <button type="submit" class="dash-btn-primary mt-6">Guardar canales</button>
    </form>
  </div>
</div>

<script>
document.getElementById('channelsForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    welcomeChannel: fd.get('welcomeChannel') || null,
    leaveChannel: fd.get('leaveChannel') || null,
    levelChannel: fd.get('levelChannel') || null,
    economyChannel: fd.get('economyChannel') || null,
    verificationChannel: fd.get('verificationChannel') || null,
    starboardChannel: fd.get('starboardChannel') || null,
    ticketCategory: fd.get('ticketCategory') || null,
    ticketLog: fd.get('ticketLog') || null,
    confessionChannel: fd.get('confessionChannel') || null,
    confessionReviewChannel: fd.get('confessionReviewChannel') || null,
    suggestionChannel: fd.get('suggestionChannel') || null,
    birthdayChannel: fd.get('birthdayChannel') || null,
    tempvcPanelChannel: fd.get('tempvcPanelChannel') || null,
    tempvcCategory: fd.get('tempvcCategory') || null,
    logChannels: {
      mod: fd.get('logChannels.mod') || null,
      message: fd.get('logChannels.message') || null,
      member: fd.get('logChannels.member') || null,
      server: fd.get('logChannels.server') || null,
      ticket: fd.get('logChannels.ticket') || null,
    },
    statsChannels: {
      members: fd.get('statsChannels.members') || null,
      online: fd.get('statsChannels.online') || null,
      boosts: fd.get('statsChannels.boosts') || null,
    },
  });
});
</script>