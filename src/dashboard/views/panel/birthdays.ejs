<div class="space-y-6 max-w-4xl">
  <div class="dash-hero">
    <div class="relative z-10">
      <p class="text-pink-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Celebraciones</p>
      <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">🎂 Cumpleaños</h1>
      <p class="text-slate-500 text-sm">Anuncios automáticos y rol temporal el día del cumpleaños.</p>
    </div>
  </div>
  <div class="dash-card p-6">
    <form id="birthdaysForm" class="space-y-5">
      <label class="flex items-center gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 cursor-pointer">
        <input type="checkbox" name="birthdays_enabled" <%= modules.find(m=>m.name==='birthdays')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="font-semibold text-slate-200">Activar Cumpleaños</span>
      </label>
      <div class="grid sm:grid-cols-2 gap-4">
        <div><label class="block text-xs text-slate-500 mb-1.5">Canal</label><%- channelSelect('birthdayChannel', settings.birthdayChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Rol cumpleañero</label><%- roleSelect('birthdayRole', settings.birthdayRole) %></div>
      </div>
      <button type="submit" class="dash-btn-primary">Guardar</button>
    </form>
  </div>
</div>
<script>
document.getElementById('birthdaysForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    birthdayChannel: fd.get('birthdayChannel') || null,
    birthdayRole: fd.get('birthdayRole') || null,
  });
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { birthdays: fd.get('birthdays_enabled') === 'on' } });
});
</script>