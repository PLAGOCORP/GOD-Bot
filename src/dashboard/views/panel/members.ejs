                <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center text-xs">👤</div>
                <div>
                  <div class="text-slate-200 font-medium">Moderador#9012</div>
                  <div class="text-xs text-slate-500 font-mono">555888999</div>
                </div>
              </div>
