        <option value="name">Nombre (A-Z)</option>
        <option value="joined">Recién Unido</option>
        <option value="level">Nivel (Mayor)</option>
        <option value="warnings">Warnings</option>
      </select>
    </div>
    <div class="flex gap-2 flex-wrap">
      <span class="text-xs bg-dark-800 px-3 py-1 rounded-full text-slate-400">Mostrando 1-50 de 342 miembros</span>
