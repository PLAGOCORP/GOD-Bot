<div class="max-w-3xl space-y-6">
  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-xl font-semibold mb-4">Invites</h2>
    <form id="invitesForm" class="space-y-4">
      <label class="flex items-center gap-3">
        <input type="checkbox" name="invites_enabled" <%= modules.find(m=>m.name==='invites')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="font-medium">Activar Invites</span>
      </label>

      <button type="submit" class="mt-4 bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2 rounded-lg">Guardar</button>
    </form>
  </div>
</div>

<script>
document.getElementById('invitesForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const mod = fd.get('invites_enabled') === 'on';
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { invites: mod } });
});
</script>