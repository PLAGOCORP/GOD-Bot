<div class="max-w-3xl space-y-6">
  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-xl font-semibold mb-4">Mensajes de Bienvenida / Despedida</h2>
    <form id="welcomeForm" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Mensaje de Bienvenida</label>
        <textarea name="welcomeMessage" rows="3" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full"><%= settings.welcomeMessage || '¡Bienvenido {user} a **{server}**! Eres el miembro #{count}.' %></textarea>
        <p class="text-xs text-slate-500 mt-1">Variables: {user}, {server}, {count}</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Mensaje de Despedida</label>
        <textarea name="leaveMessage" rows="3" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full"><%= settings.leaveMessage || '**{user}** ha abandonado **{server}**.' %></textarea>
        <p class="text-xs text-slate-500 mt-1">Variables: {user}, {server}</p>
      </div>
      <label class="flex items-center gap-3">
        <input type="checkbox" name="welcomeDm" <%= settings.welcomeDm ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="text-sm">Enviar bienvenida por DM</span>
      </label>
      <button type="submit" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2 rounded-lg">Guardar</button>
    </form>
  </div>

  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-xl font-semibold mb-4">Verificación</h2>
    <form id="verifyForm" class="space-y-4">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Canal de Verificación</label>
          <%- channelSelect('verificationChannel', settings.verificationChannel) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Rol Verificado</label>
          <%- roleSelect('verifiedRole2', settings.verifiedRole) %>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Quiz de Verificación (JSON)</label>
        <textarea name="verifyQuiz" rows="4" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full font-mono text-sm"><%= JSON.stringify(settings.verifyQuiz, null, 2) %></textarea>
        <p class="text-xs text-slate-500 mt-1">Formato: [{"q":"pregunta","a":"respuesta"}]</p>
      </div>
      <button type="submit" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2 rounded-lg">Guardar</button>
    </form>
  </div>
</div>

<script>
document.getElementById('welcomeForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    welcomeMessage: fd.get('welcomeMessage'),
    leaveMessage: fd.get('leaveMessage'),
    welcomeDm: fd.get('welcomeDm') === 'on',
  });
});
document.getElementById('verifyForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  let quiz = null;
  try { quiz = JSON.parse(fd.get('verifyQuiz')); } catch { showToast('JSON de quiz inválido', 'error'); return; }
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    verificationChannel: fd.get('verificationChannel') || null,
    verifiedRole: fd.get('verifiedRole2') || null,
    verifyQuiz: quiz,
  });
});
</script>