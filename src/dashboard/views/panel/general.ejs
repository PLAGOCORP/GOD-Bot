<% const ownerIdsStr = Array.isArray(settings.ownerIds) ? settings.ownerIds.join(', ') : (settings.ownerIds || ''); %>
<div class="space-y-6 max-w-4xl" id="generalPanel" data-guild-id="<%= guild.id %>">
  <div class="dash-hero">
    <div class="relative z-10">
      <p class="text-amber-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Servidor</p>
      <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">⚙️ General</h1>
      <p class="text-slate-500 text-sm">Prefijo, idioma, owners del bot y módulos activos.</p>
    </div>
  </div>

  <div class="dash-card p-6">
    <h2 class="text-sm font-bold text-slate-300 mb-4">Configuración básica</h2>
    <form id="generalForm" class="space-y-4">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-slate-500 mb-1.5" for="prefix">Prefijo (comandos de texto)</label>
          <input type="text" id="prefix" name="prefix" value="<%= settings.prefix || 'g!' %>" class="servers-search w-full" style="padding-left:1rem" maxlength="5"/>
        </div>
        <div>
          <label class="block text-xs text-slate-500 mb-1.5" for="language">Idioma</label>
          <select id="language" name="language" class="servers-search w-full" style="padding-left:1rem">
            <option value="es" <%= (settings.language || 'es') === 'es' ? 'selected' : '' %>>Español</option>
            <option value="en" <%= settings.language === 'en' ? 'selected' : '' %>>English</option>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-xs text-slate-500 mb-1.5" for="ownerIds">Owner IDs (separados por coma)</label>
        <input type="text" id="ownerIds" name="ownerIds" value="<%= ownerIdsStr %>" class="servers-search w-full font-mono text-sm" style="padding-left:1rem" placeholder="123456789012345678, 987654321098765432"/>
        <p class="text-xs text-slate-600 mt-1.5">Usuarios con permisos de owner del bot en este servidor (además de los owners globales).</p>
      </div>
      <button type="submit" class="dash-btn-primary">Guardar configuración</button>
    </form>
  </div>

  <div class="dash-card p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-bold text-slate-300">Módulos</h2>
      <span class="text-xs text-slate-600"><%= modules.filter(m => m.enabled).length %>/<%= modules.length %> activos</span>
    </div>
    <form id="modulesForm" class="space-y-3">
      <input type="hidden" name="_modules" value="<%= modules.map(m => m.name).join(',') %>"/>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2 max-h-96 overflow-y-auto pr-1">
        <% modules.forEach(function(m) { %>
          <label class="flex items-center gap-2.5 py-2 px-3 rounded-lg bg-white/[0.02] border border-white/5 hover:border-amber-500/20 transition cursor-pointer">
            <input type="checkbox" name="mod_<%= m.name %>" <%= m.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
            <span class="font-mono text-xs text-slate-300"><%= m.name %></span>
          </label>
        <% }) %>
      </div>
      <button type="submit" class="dash-btn-primary mt-2">Guardar módulos</button>
    </form>
  </div>
</div>

<script>
document.getElementById('generalForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    prefix: (fd.get('prefix') || 'g!').trim(),
    language: fd.get('language') || 'es',
    ownerIds: (fd.get('ownerIds') || '').trim(),
  });
});
document.getElementById('modulesForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const modules = {};
  fd.getAll('_modules').join(',').split(',').filter(Boolean).forEach((m) => {
    modules[m] = fd.get('mod_' + m) === 'on';
  });
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules });
});
</script>