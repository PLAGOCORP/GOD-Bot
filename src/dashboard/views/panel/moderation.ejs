<div class="space-y-6 max-w-4xl" id="moderationPanel" data-guild-id="<%= guild.id %>">
  <div class="dash-hero">
    <div class="relative z-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <p class="text-orange-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Staff</p>
        <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">🛡️ Moderación</h1>
        <p class="text-slate-500 text-sm">Roles del staff, canal de logs y acceso rápido a herramientas.</p>
      </div>
      <a href="/servers/<%= guild.id %>/panel/members" class="dash-btn-primary self-start sm:self-center text-center no-underline">👥 Gestionar miembros</a>
    </div>
  </div>

  <div class="grid sm:grid-cols-2 gap-4">
    <div class="dash-stat-card stat-orange">
      <div class="text-slate-500 text-xs uppercase font-semibold">Warns activos</div>
      <div class="text-2xl font-black text-orange-400"><%= panelStats.warns ?? '—' %></div>
    </div>
    <div class="dash-stat-card stat-cyan">
      <div class="text-slate-500 text-xs uppercase font-semibold">Tickets abiertos</div>
      <div class="text-2xl font-black text-cyan-400"><%= panelStats.tickets ?? '—' %></div>
    </div>
  </div>

  <div class="dash-card p-6">
    <form id="moderationForm" class="space-y-5">
      <label class="flex items-center gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 cursor-pointer">
        <input type="checkbox" name="moderation_enabled" <%= modules.find(m=>m.name==='moderation')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <div>
          <span class="font-semibold text-slate-200">Activar módulo Moderación</span>
          <p class="text-xs text-slate-600 mt-0.5">Comandos /moderacion: ban, kick, warn, timeout, purge…</p>
        </div>
      </label>

      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-slate-500 mb-1.5">Rol moderador</label>
          <%- roleSelect('modRole', settings.modRole) %>
        </div>
        <div>
          <label class="block text-xs text-slate-500 mb-1.5">Rol mute</label>
          <%- roleSelect('muteRole', settings.muteRole) %>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-xs text-slate-500 mb-1.5">Canal log moderación</label>
          <%- channelSelect('logMod', settings.logChannels?.mod) %>
        </div>
      </div>

      <div>
        <label class="block text-xs text-slate-500 mb-2">Roles staff adicionales</label>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2 max-h-52 overflow-y-auto pr-1">
          <% if (!roles.length) { %>
            <p class="text-sm text-slate-600 col-span-full">Bot sin acceso al servidor o sin roles cargados.</p>
          <% } %>
          <% roles.forEach(function(r) { %>
            <label class="flex items-center gap-2 py-2 px-3 rounded-lg bg-white/[0.02] border border-white/5 hover:border-orange-500/20 transition cursor-pointer">
              <input type="checkbox" name="staffRole_<%= r.id %>" <%= (settings.staffRoles || []).includes(r.id) ? 'checked' : '' %> class="rounded accent-amber-400"/>
              <span class="text-xs text-slate-300 truncate">@<%= r.name %></span>
            </label>
          <% }) %>
        </div>
        <p class="text-xs text-slate-600 mt-1.5">Usuarios con estos roles pueden usar comandos de mod aunque no tengan permisos de Discord.</p>
      </div>

      <button type="submit" class="dash-btn-primary">Guardar</button>
    </form>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
    <a href="/servers/<%= guild.id %>/panel/audit" class="dash-card p-4 hover:border-amber-500/20 transition no-underline block">
      <div class="text-lg mb-1">📋</div>
      <div class="text-sm font-semibold text-slate-200">Auditoría</div>
      <div class="text-xs text-slate-600">Historial de acciones</div>
    </a>
    <a href="/servers/<%= guild.id %>/panel/logging" class="dash-card p-4 hover:border-amber-500/20 transition no-underline block">
      <div class="text-lg mb-1">📝</div>
      <div class="text-sm font-semibold text-slate-200">Logs</div>
      <div class="text-xs text-slate-600">Todos los canales de log</div>
    </a>
    <a href="/servers/<%= guild.id %>/panel/automod" class="dash-card p-4 hover:border-amber-500/20 transition no-underline block">
      <div class="text-lg mb-1">🤖</div>
      <div class="text-sm font-semibold text-slate-200">AutoMod</div>
      <div class="text-xs text-slate-600">Filtros automáticos</div>
    </a>
    <a href="/servers/<%= guild.id %>/panel/security" class="dash-card p-4 hover:border-amber-500/20 transition no-underline block">
      <div class="text-lg mb-1">🔐</div>
      <div class="text-sm font-semibold text-slate-200">Seguridad</div>
      <div class="text-xs text-slate-600">Anti-raid y anti-nuke</div>
    </a>
  </div>
</div>

<script>
document.getElementById('moderationForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const staffRoles = [];
  <% roles.forEach(function(r) { %>
  if (fd.get('staffRole_<%= r.id %>') === 'on') staffRoles.push('<%= r.id %>');
  <% }) %>

  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    modRole: fd.get('modRole') || null,
    muteRole: fd.get('muteRole') || null,
    logChannels: {
      mod: fd.get('logMod') || null,
    },
    staffRoles,
  });
  const mod = fd.get('moderation_enabled') === 'on';
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { moderation: mod } });
});
</script>