<div class="space-y-6 max-w-4xl">
  <div class="dash-hero">
    <div class="relative z-10">
      <p class="text-red-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Protección</p>
      <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">🔐 Seguridad</h1>
      <p class="text-slate-500 text-sm">Anti-nuke, anti-raid y quiz de verificación avanzado.</p>
    </div>
  </div>

  <div class="dash-card p-6">
    <h2 class="text-sm font-bold text-slate-300 mb-4">Anti-Nuke</h2>
    <form id="antinukeForm" class="space-y-4">
      <label class="flex items-center gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 cursor-pointer">
        <input type="checkbox" name="antinuke_enabled" <%= modules.find(m=>m.name==='antinuke')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="font-semibold text-slate-200">Activar Anti-Nuke</span>
      </label>
      <div class="grid sm:grid-cols-2 gap-4">
        <div><label class="block text-xs text-slate-500 mb-1.5">Threshold (acciones)</label><input type="number" name="antinukeThreshold" value="<%= settings.antinukeThreshold || 3 %>" class="servers-search w-full" style="padding-left:1rem"/></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Ventana (ms)</label><input type="number" name="antinukeWindowMs" value="<%= settings.antinukeWindowMs || 10000 %>" class="servers-search w-full" style="padding-left:1rem"/></div>
      </div>
      <button type="submit" class="dash-btn-primary">Guardar Anti-Nuke</button>
    </form>
  </div>

  <div class="dash-card p-6">
    <h2 class="text-sm font-bold text-slate-300 mb-4">Anti-Raid</h2>
    <form id="antiraidForm" class="space-y-4">
      <label class="flex items-center gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 cursor-pointer">
        <input type="checkbox" name="antiraid_enabled" <%= modules.find(m=>m.name==='antiraid')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="font-semibold text-slate-200">Activar Anti-Raid</span>
      </label>
      <div class="grid sm:grid-cols-2 gap-4">
        <div><label class="block text-xs text-slate-500 mb-1.5">Threshold (joins)</label><input type="number" name="antiraidThreshold" value="<%= settings.antiraidThreshold || 8 %>" class="servers-search w-full" style="padding-left:1rem"/></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Ventana (ms)</label><input type="number" name="antiraidWindowMs" value="<%= settings.antiraidWindowMs || 15000 %>" class="servers-search w-full" style="padding-left:1rem"/></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Lockdown (min)</label><input type="number" name="antiraidLockMinutes" value="<%= settings.antiraidLockMinutes || 10 %>" class="servers-search w-full" style="padding-left:1rem"/></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Edad mín. cuenta (h)</label><input type="number" name="minAccountAgeHours" value="<%= settings.minAccountAgeHours || 0 %>" class="servers-search w-full" style="padding-left:1rem"/></div>
      </div>
      <label class="flex items-center gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 cursor-pointer">
        <input type="checkbox" name="kickNewAccounts" <%= settings.kickNewAccounts ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="text-sm text-slate-300">Expulsar si no cumple edad mínima</span>
      </label>
      <label class="flex items-center gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 cursor-pointer">
        <input type="checkbox" name="antiraidKick" <%= settings.antiraidKick ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="text-sm text-slate-300">Expulsar cuentas nuevas en raid</span>
      </label>
      <button type="submit" class="dash-btn-primary">Guardar Anti-Raid</button>
    </form>
  </div>

  <div class="dash-card p-6">
    <h2 class="text-sm font-bold text-slate-300 mb-4">Quiz de verificación</h2>
    <form id="verifyQuizForm" class="space-y-4">
      <textarea name="verifyQuiz" rows="4" class="dash-textarea font-mono text-xs"><%= JSON.stringify(settings.verifyQuiz, null, 2) %></textarea>
      <p class="text-xs text-slate-600">Formato: [{"q":"pregunta","a":"respuesta"}]</p>
      <button type="submit" class="dash-btn-primary">Guardar quiz</button>
    </form>
  </div>
</div>

<script>
document.getElementById('antinukeForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    antinukeThreshold: parseInt(fd.get('antinukeThreshold'), 10) || 3,
    antinukeWindowMs: parseInt(fd.get('antinukeWindowMs'), 10) || 10000,
  });
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { antinuke: fd.get('antinuke_enabled') === 'on' } });
});
document.getElementById('antiraidForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    antiraidThreshold: parseInt(fd.get('antiraidThreshold'), 10) || 8,
    antiraidWindowMs: parseInt(fd.get('antiraidWindowMs'), 10) || 15000,
    antiraidLockMinutes: parseInt(fd.get('antiraidLockMinutes'), 10) || 10,
    minAccountAgeHours: parseInt(fd.get('minAccountAgeHours'), 10) || 0,
    antiraidKick: fd.get('antiraidKick') === 'on',
    kickNewAccounts: fd.get('kickNewAccounts') === 'on',
  });
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { antiraid: fd.get('antiraid_enabled') === 'on' } });
});
document.getElementById('verifyQuizForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  let quiz = null;
  try { quiz = JSON.parse(fd.get('verifyQuiz')); } catch { showToast('JSON inválido', 'error'); return; }
  await saveSettings('/api/guilds/<%= guild.id %>/settings', { verifyQuiz: quiz });
});
</script>