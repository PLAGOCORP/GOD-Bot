<div class="max-w-3xl space-y-6">
  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-xl font-semibold mb-4">Economía</h2>
    <form id="economyForm" class="space-y-4">
      <label class="flex items-center gap-3">
        <input type="checkbox" name="economy_enabled" <%= modules.find(m=>m.name==='economy')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="font-medium">Activar Economía</span>
      </label>

      <div class="grid sm:grid-cols-2 gap-4 mt-4">
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Balance inicial</label>
          <input type="number" name="startingBalance" value="<%= settings.startingBalance || 200 %>" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Daily Mínimo</label>
          <input type="number" name="dailyMin" value="<%= settings.dailyMin || 100 %>" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Daily Máximo</label>
          <input type="number" name="dailyMax" value="<%= settings.dailyMax || 500 %>" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Work Mínimo</label>
          <input type="number" name="workMin" value="<%= settings.workMin || 50 %>" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Work Máximo</label>
          <input type="number" name="workMax" value="<%= settings.workMax || 250 %>" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Cooldown Daily (ms)</label>
          <input type="number" name="dailyCooldown" value="<%= settings.dailyCooldown || 86400000 %>" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Cooldown Work (ms)</label>
          <input type="number" name="workCooldown" value="<%= settings.workCooldown || 3600000 %>" class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full"/>
        </div>
      </div>

      <button type="submit" class="mt-4 bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2 rounded-lg">Guardar</button>
    </form>
  </div>
</div>

<script>
document.getElementById('economyForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    startingBalance: parseInt(fd.get('startingBalance')) || 200,
    dailyMin: parseInt(fd.get('dailyMin')) || 100,
    dailyMax: parseInt(fd.get('dailyMax')) || 500,
    workMin: parseInt(fd.get('workMin')) || 50,
    workMax: parseInt(fd.get('workMax')) || 250,
    dailyCooldown: parseInt(fd.get('dailyCooldown')) || 86400000,
    workCooldown: parseInt(fd.get('workCooldown')) || 3600000,
  });
  const mod = fd.get('economy_enabled') === 'on';
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { economy: mod } });
});
</script>