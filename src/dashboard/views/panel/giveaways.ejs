<div class="space-y-6 max-w-3xl">
  <div class="dash-hero">
    <div class="relative z-10">
      <p class="text-pink-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Eventos</p>
      <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">🎁 Sorteos</h1>
      <p class="text-slate-500 text-sm">Gestión automática de giveaways con <code class="text-amber-400/80">/sorteo</code>.</p>
    </div>
  </div>
  <div class="dash-card p-6">
    <form id="giveawaysForm" class="space-y-5">
      <label class="flex items-center gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 cursor-pointer">
        <input type="checkbox" name="giveaways_enabled" <%= modules.find(m=>m.name==='giveaways')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="font-semibold text-slate-200">Activar Sorteos</span>
      </label>
      <div>
        <label class="block text-xs text-slate-500 mb-1.5">Intervalo verificación (ms)</label>
        <input type="number" name="checkIntervalMs" value="<%= settings.checkIntervalMs || 15000 %>" class="servers-search w-full sm:w-64" style="padding-left:1rem"/>
        <p class="text-xs text-slate-600 mt-1">Cada cuánto el bot revisa sorteos expirados (default 15s).</p>
      </div>
      <button type="submit" class="dash-btn-primary">Guardar</button>
    </form>
  </div>
</div>
<script>
document.getElementById('giveawaysForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', { checkIntervalMs: parseInt(fd.get('checkIntervalMs'), 10) || 15000 });
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { giveaways: fd.get('giveaways_enabled') === 'on' } });
});
</script>