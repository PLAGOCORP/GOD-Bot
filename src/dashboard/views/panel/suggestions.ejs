<div class="space-y-6 max-w-4xl" id="suggestionsPanel" data-guild-id="<%= guild.id %>">
  <div class="dash-hero">
    <div class="relative z-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <p class="text-amber-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Comunidad</p>
        <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">💡 Sugerencias</h1>
        <p class="text-slate-500 text-sm">Los usuarios envían ideas con <code class="text-amber-400/80">/sugerir enviar</code> y el staff las aprueba o rechaza.</p>
      </div>
      <div class="dash-stat-card stat-amber self-start sm:self-center" style="padding:0.85rem 1.1rem">
        <div class="text-slate-500 text-xs uppercase font-semibold">Pendientes</div>
        <div class="text-2xl font-black text-amber-400" id="stat-pending"><%= panelStats.pending ?? 0 %></div>
      </div>
    </div>
  </div>

  <div class="dash-card p-6">
    <form id="suggestionsForm" class="space-y-5">
      <label class="flex items-center gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 cursor-pointer">
        <input type="checkbox" name="suggestions_enabled" <%= modules.find(m=>m.name==='suggestions')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <div>
          <span class="font-semibold text-slate-200">Activar Sugerencias</span>
          <p class="text-xs text-slate-600 mt-0.5">Publica en el canal configurado con botones de voto 👍👎</p>
        </div>
      </label>

      <div>
        <label class="block text-xs text-slate-500 mb-1.5">Canal de sugerencias</label>
        <%- channelSelect('suggestionChannel', settings.suggestionChannel) %>
      </div>

      <button type="submit" class="dash-btn-primary">Guardar configuración</button>
    </form>
  </div>

  <div class="dash-card overflow-hidden">
    <div class="p-5 border-b border-white/5 flex items-center justify-between gap-3">
      <h2 class="text-sm font-bold text-slate-300">Pendientes de revisión</h2>
      <button type="button" id="btnRefresh" class="text-xs px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-slate-400 hover:text-white transition">↻ Actualizar</button>
    </div>
    <div id="suggestionsList" class="divide-y divide-white/5">
      <p class="px-5 py-10 text-center text-slate-500 text-sm">Cargando...</p>
    </div>
    <div class="p-4 flex items-center justify-center gap-3 border-t border-white/5" id="pagination" hidden>
      <button type="button" id="btnPrev" class="px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-slate-400 text-sm disabled:opacity-40" disabled>←</button>
      <span class="text-slate-500 text-xs" id="pageInfo">Página 1</span>
      <button type="button" id="btnNext" class="px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-slate-400 text-sm disabled:opacity-40" disabled>→</button>
    </div>
  </div>
</div>

<script>
(function () {
  const guildId = document.getElementById('suggestionsPanel').dataset.guildId;
  let state = { page: 1, pages: 1, loading: false };

  const els = {
    list: document.getElementById('suggestionsList'),
    pending: document.getElementById('stat-pending'),
    pagination: document.getElementById('pagination'),
    pageInfo: document.getElementById('pageInfo'),
    prev: document.getElementById('btnPrev'),
    next: document.getElementById('btnNext'),
  };

  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
  }

  function formatDate(ts) {
    if (!ts) return '—';
    return new Date(ts).toLocaleString('es-ES', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
  }

  async function loadQueue() {
    if (state.loading) return;
    state.loading = true;
    els.list.innerHTML = '<p class="px-5 py-10 text-center text-slate-500 text-sm">Cargando...</p>';
    try {
      const res = await fetch(`/api/guilds/${guildId}/suggestions?status=pending&page=${state.page}&limit=8`);
      const data = await res.json();
      if (!data.ok) throw new Error(data.error || 'Error');

      state.pages = data.pages;
      els.pending.textContent = data.total;
      els.pageInfo.textContent = `Página ${data.page} de ${data.pages}`;
      els.prev.disabled = data.page <= 1;
      els.next.disabled = data.page >= data.pages;
      els.pagination.hidden = data.pages <= 1;

      if (!data.suggestions.length) {
        els.list.innerHTML = '<p class="px-5 py-10 text-center text-slate-500 text-sm">No hay sugerencias pendientes 🎉</p>';
        return;
      }

      els.list.innerHTML = data.suggestions.map((s) => `
        <div class="p-5 hover:bg-white/[0.02] transition">
          <div class="flex items-start justify-between gap-3 mb-2">
            <div>
              <span class="text-xs font-mono text-amber-400/80">#${escapeHtml(s.id.slice(0, 8))}</span>
              <span class="text-xs text-slate-500 ml-2">por <strong class="text-slate-400">${escapeHtml(s.authorName)}</strong></span>
            </div>
            <span class="text-xs text-slate-600 whitespace-nowrap">${formatDate(s.createdAt)}</span>
          </div>
          <p class="text-sm text-slate-300 whitespace-pre-wrap break-words mb-4">${escapeHtml(s.preview)}${(s.content || '').length > 280 ? '…' : ''}</p>
          <div class="flex gap-2 flex-wrap">
            <button type="button" class="sug-action px-3 py-1.5 rounded-lg text-xs font-semibold bg-emerald-500/15 text-emerald-300 hover:bg-emerald-500/25 transition" data-action="approve" data-id="${s.id}">✓ Aprobar</button>
            <button type="button" class="sug-action px-3 py-1.5 rounded-lg text-xs font-semibold bg-red-500/10 text-red-300 hover:bg-red-500/20 transition" data-action="reject" data-id="${s.id}">✕ Rechazar</button>
            ${s.messageId && s.channelId ? `<a href="https://discord.com/channels/${guildId}/${s.channelId}/${s.messageId}" target="_blank" rel="noopener" class="px-3 py-1.5 rounded-lg text-xs text-slate-500 hover:text-slate-300 border border-white/10">Ver en Discord ↗</a>` : ''}
          </div>
        </div>
      `).join('');
    } catch (e) {
      els.list.innerHTML = `<p class="px-5 py-10 text-center text-red-400 text-sm">${escapeHtml(e.message)}</p>`;
    } finally {
      state.loading = false;
    }
  }

  async function moderate(id, action) {
    const label = action === 'approve' ? 'aprobar' : 'rechazar';
    if (!confirm(`¿Confirmas ${label} esta sugerencia?`)) return;
    try {
      const res = await fetch(`/api/guilds/${guildId}/suggestions/${id}/moderate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action }),
      });
      const data = await res.json();
      if (!data.ok) throw new Error(data.error);
      showToast(data.message || 'Hecho');
      loadQueue();
    } catch (e) {
      showToast(e.message, 'error');
    }
  }

  document.getElementById('suggestionsForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    await saveSettings('/api/guilds/<%= guild.id %>/settings', {
      suggestionChannel: fd.get('suggestionChannel') || null,
    });
    const mod = fd.get('suggestions_enabled') === 'on';
    await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { suggestions: mod } });
  });

  document.getElementById('btnRefresh').addEventListener('click', () => loadQueue());
  els.prev.addEventListener('click', () => { if (state.page > 1) { state.page--; loadQueue(); } });
  els.next.addEventListener('click', () => { if (state.page < state.pages) { state.page++; loadQueue(); } });

  els.list.addEventListener('click', (e) => {
    const btn = e.target.closest('.sug-action');
    if (!btn) return;
    moderate(btn.dataset.id, btn.dataset.action);
  });

  loadQueue();
})();
</script>