<div class="max-w-3xl space-y-6">
  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-xl font-semibold mb-4">Sugerencias</h2>
    <form id="suggestionsForm" class="space-y-4">
      <label class="flex items-center gap-3">
        <input type="checkbox" name="suggestions_enabled" <%= modules.find(m=>m.name==='suggestions')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="font-medium">Activar Sugerencias</span>
      </label>

      <div class="mt-4">
        <label class="block text-sm font-medium text-slate-400 mb-1">Canal Sugerencias</label>
        <%- channelSelect('suggestionChannel', settings.suggestionChannel) %>
      </div>

      <button type="submit" class="mt-4 bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2 rounded-lg">Guardar</button>
    </form>
  </div>
</div>

<script>
document.getElementById('suggestionsForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    suggestionChannel: fd.get('suggestionChannel') || null,
  });
  const mod = fd.get('suggestions_enabled') === 'on';
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { suggestions: mod } });
});
</script>