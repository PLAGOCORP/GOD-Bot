<%
  const enabledCount = modules.filter(m => m.enabled).length;
  const modulePct = modules.length ? Math.round((enabledCount / modules.length) * 100) : 0;
  const circumference = 2 * Math.PI * 18;
  const dashOffset = circumference - (modulePct / 100) * circumference;
%>

<div class="space-y-6 max-w-6xl">
  <!-- Hero -->
  <div class="dash-hero flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div class="relative z-10">
      <p class="text-amber-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Panel de control</p>
      <h1 class="text-2xl sm:text-3xl font-black text-white mb-1"><%= guild.name %></h1>
      <p class="text-slate-500 text-sm font-mono"><%= guild.id %></p>
    </div>
    <div class="relative z-10 flex items-center gap-4">
      <div class="dash-progress-ring">
        <svg width="72" height="72" viewBox="0 0 44 44">
          <defs>
            <linearGradient id="amberGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#fbbf24"/>
              <stop offset="100%" stop-color="#d97706"/>
            </linearGradient>
          </defs>
          <circle class="ring-bg" cx="22" cy="22" r="18" fill="none" stroke-width="3"/>
          <circle class="ring-fg" cx="22" cy="22" r="18" fill="none" stroke-width="3"
            stroke-dasharray="<%= circumference %>"
            stroke-dashoffset="<%= dashOffset %>"/>
        </svg>
        <div>
          <span class="text-lg font-black text-amber-400"><%= modulePct %>%</span>
        </div>
      </div>
      <div>
        <div class="text-sm font-semibold text-slate-300">Módulos activos</div>
        <div class="text-xs text-slate-500"><%= enabledCount %> de <%= modules.length %></div>
      </div>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid sm:grid-cols-2 xl:grid-cols-4 gap-4">
    <div class="dash-stat-card stat-amber">
      <div class="dash-stat-icon amber">👥</div>
      <div class="text-slate-400 text-xs font-semibold uppercase tracking-wide mb-1">Miembros</div>
      <div class="text-3xl font-black text-amber-400"><%= stats.memberCount || 0 %></div>
      <div class="text-slate-600 text-xs mt-1">usuarios activos</div>
    </div>
    <div class="dash-stat-card stat-blue">
      <div class="dash-stat-icon blue">#️⃣</div>
      <div class="text-slate-400 text-xs font-semibold uppercase tracking-wide mb-1">Canales</div>
      <div class="text-3xl font-black text-blue-400"><%= stats.channelCount || 0 %></div>
      <div class="text-slate-600 text-xs mt-1">canales de chat</div>
    </div>
    <div class="dash-stat-card stat-purple">
      <div class="dash-stat-icon purple">🎯</div>
      <div class="text-slate-400 text-xs font-semibold uppercase tracking-wide mb-1">Roles</div>
      <div class="text-3xl font-black text-purple-400"><%= stats.roleCount || 0 %></div>
      <div class="text-slate-600 text-xs mt-1">roles disponibles</div>
    </div>
    <div class="dash-stat-card stat-emerald">
      <div class="dash-stat-icon emerald">⚡</div>
      <div class="text-slate-400 text-xs font-semibold uppercase tracking-wide mb-1">Versión</div>
      <div class="text-2xl font-black text-emerald-400"><%= botVersion %></div>
      <div class="text-slate-600 text-xs mt-1">G.O.D. Bot</div>
    </div>
  </div>

  <% if (stats.openTickets > 0 || stats.pendingConfessions > 0) { %>
  <div class="dash-alert">
    <div class="font-bold text-orange-400 mb-2 flex items-center gap-2">
      <span>⚠️</span> Acciones pendientes
    </div>
    <div class="space-y-1 text-sm text-slate-300">
      <% if (stats.openTickets > 0) { %>
        <div>📋 <strong><%= stats.openTickets %></strong> ticket<%= stats.openTickets !== 1 ? 's' : '' %> abierto<%= stats.openTickets !== 1 ? 's' : '' %></div>
      <% } %>
      <% if (stats.pendingConfessions > 0) { %>
        <div>💬 <strong><%= stats.pendingConfessions %></strong> confesión<%= stats.pendingConfessions !== 1 ? 'es' : '' %> por revisar</div>
      <% } %>
    </div>
  </div>
  <% } %>

  <div class="grid lg:grid-cols-2 gap-6">
    <!-- Top users -->
    <div class="dash-card p-6">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-bold text-white">🏆 Usuarios más activos</h2>
        <span class="text-xs font-semibold text-slate-500 bg-white/5 px-2.5 py-1 rounded-full">Top 5</span>
      </div>
      <div class="space-y-2">
        <% if (stats.topUsers && stats.topUsers.length > 0) { %>
          <% stats.topUsers.forEach((u, i) => { %>
            <div class="dash-rank-row">
              <div class="flex items-center gap-3">
                <span class="dash-rank-num <%= i === 0 ? 'gold' : i === 1 ? 'silver' : i === 2 ? 'bronze' : '' %>"><%= i + 1 %></span>
                <div>
                  <div class="font-semibold text-slate-200 text-sm"><%= u.username %></div>
                  <div class="text-xs text-slate-500">Nivel <strong class="text-amber-400/80"><%= u.level %></strong></div>
                </div>
              </div>
              <div class="text-right">
                <div class="text-emerald-400 font-bold text-sm font-mono"><%= u.balance.toLocaleString('es-ES') %></div>
                <div class="text-xs text-slate-600">coins</div>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="text-center py-10 text-slate-500 text-sm">
            <div class="text-3xl mb-2 opacity-40">📊</div>
            Sin actividad registrada aún
          </div>
        <% } %>
      </div>
    </div>

    <!-- Modules -->
    <div class="dash-card p-6">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-lg font-bold text-white">🔌 Módulos</h2>
        <a href="/servers/<%= guild.id %>/panel/general" class="text-xs text-amber-400 hover:text-amber-300 transition font-medium">Configurar →</a>
      </div>
      <%
        const enabled = modules.filter(m => m.enabled);
        const disabled = modules.filter(m => !m.enabled);
      %>
      <% if (enabled.length > 0) { %>
        <div class="text-xs text-emerald-400/80 font-bold uppercase tracking-wide mb-3">Activos</div>
        <div class="flex flex-wrap gap-2 mb-5">
          <% enabled.forEach(m => { %>
            <span class="dash-module-pill on"><%= m.name %></span>
          <% }); %>
        </div>
      <% } %>
      <% if (disabled.length > 0) { %>
        <div class="text-xs text-slate-500 font-bold uppercase tracking-wide mb-3">Inactivos</div>
        <div class="flex flex-wrap gap-2">
          <% disabled.slice(0, 8).forEach(m => { %>
            <span class="dash-module-pill off"><%= m.name %></span>
          <% }); %>
          <% if (disabled.length > 8) { %>
            <span class="text-xs text-slate-600 self-center">+<%= disabled.length - 8 %> más</span>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Quick actions -->
  <div class="dash-card p-6">
    <h2 class="text-lg font-bold text-white mb-5">⚡ Acciones rápidas</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
      <% const actions = [
        { href:'general', icon:'⚙️', label:'Configuración' },
        { href:'moderation', icon:'🛡️', label:'Moderación' },
        { href:'tickets', icon:'📋', label:'Tickets' },
        { href:'logging', icon:'📊', label:'Logs' },
        { href:'economy', icon:'💰', label:'Economía' },
        { href:'leveling', icon:'📈', label:'Niveles' },
        { href:'security', icon:'🔐', label:'Seguridad' },
        { href:'confessions', icon:'💬', label:'Confesiones' },
      ]; %>
      <% actions.forEach(function(a) { %>
        <a href="/servers/<%= guild.id %>/panel/<%= a.href %>" class="dash-quick-action">
          <span class="qa-icon"><%= a.icon %></span>
          <%= a.label %>
        </a>
      <% }) %>
    </div>
  </div>

  <!-- Tips -->
  <div class="dash-card p-6">
    <h2 class="text-lg font-bold text-white mb-4">💡 Tips</h2>
    <div class="grid sm:grid-cols-2 gap-3 text-sm text-slate-400">
      <div class="flex gap-3 p-3 rounded-lg bg-white/[0.02]"><span class="text-amber-400 font-bold">1</span><span>Activa solo los módulos que uses desde <strong class="text-slate-300">General</strong>.</span></div>
      <div class="flex gap-3 p-3 rounded-lg bg-white/[0.02]"><span class="text-amber-400 font-bold">2</span><span>Configura canales de bienvenida, logs y tickets para tu staff.</span></div>
      <div class="flex gap-3 p-3 rounded-lg bg-white/[0.02]"><span class="text-amber-400 font-bold">3</span><span>Niveles y economía se actualizan en tiempo real.</span></div>
      <div class="flex gap-3 p-3 rounded-lg bg-white/[0.02]"><span class="text-amber-400 font-bold">4</span><span>Tickets inactivos se cierran tras <strong class="text-slate-300">48h</strong>.</span></div>
    </div>
  </div>
</div>