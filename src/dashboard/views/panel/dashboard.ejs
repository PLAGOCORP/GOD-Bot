<div class="space-y-6">
  <!-- Encabezado con nombre del servidor -->
  <div class="bg-gradient-to-r from-amber-600/20 to-purple-600/20 border border-dark-700 rounded-xl p-6">
    <h1 class="text-3xl font-bold text-amber-400 mb-2"><%= guild.name %></h1>
    <p class="text-slate-400">Panel de control · <span class="text-amber-400 font-mono"><%= guild.id %></span></p>
  </div>

  <!-- Estadísticas principales (grid) -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-dark-900 border border-dark-700 rounded-xl p-4">
      <div class="text-slate-400 text-sm font-medium mb-2">👥 Miembros</div>
      <div class="text-3xl font-bold text-amber-400"><%= stats.memberCount || 0 %></div>
      <div class="text-slate-500 text-xs mt-1">usuarios activos</div>
    </div>

    <div class="bg-dark-900 border border-dark-700 rounded-xl p-4">
      <div class="text-slate-400 text-sm font-medium mb-2">#️⃣ Canales</div>
      <div class="text-3xl font-bold text-blue-400"><%= stats.channelCount || 0 %></div>
      <div class="text-slate-500 text-xs mt-1">canales de chat</div>
    </div>

    <div class="bg-dark-900 border border-dark-700 rounded-xl p-4">
      <div class="text-slate-400 text-sm font-medium mb-2">🎯 Roles</div>
      <div class="text-3xl font-bold text-purple-400"><%= stats.roleCount || 0 %></div>
      <div class="text-slate-500 text-xs mt-1">roles disponibles</div>
    </div>

    <div class="bg-dark-900 border border-dark-700 rounded-xl p-4">
      <div class="text-slate-400 text-sm font-medium mb-2">⚙️ Versión Bot</div>
      <div class="text-2xl font-bold text-slate-300"><%= botVersion %></div>
      <div class="text-slate-500 text-xs mt-1">G.O.D. Bot</div>
    </div>
  </div>

  <!-- Alertas urgentes -->
  <% if (stats.openTickets > 0 || stats.pendingConfessions > 0) { %>
  <div class="border-l-4 border-orange-500 bg-dark-900 border border-dark-700 rounded-lg p-4">
    <div class="font-semibold text-orange-400 mb-2">⚠️ Acciones Pendientes</div>
    <div class="space-y-1 text-sm">
      <% if (stats.openTickets > 0) { %>
        <div class="text-slate-300">📋 <strong><%= stats.openTickets %> ticket<%= stats.openTickets !== 1 ? 's' : '' %></strong> abierto<%= stats.openTickets !== 1 ? 's' : '' %></div>
      <% } %>
      <% if (stats.pendingConfessions > 0) { %>
        <div class="text-slate-300">💬 <strong><%= stats.pendingConfessions %> confesión<%= stats.pendingConfessions !== 1 ? 'es' : '' %></strong> pendiente<%= stats.pendingConfessions !== 1 ? 's' : '' %></div>
      <% } %>
    </div>
  </div>
  <% } %>

  <div class="grid lg:grid-cols-2 gap-6">
    <!-- Top usuarios por nivel -->
    <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
      <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
        <span>🏆 Usuarios Más Activos</span>
        <span class="text-xs bg-dark-800 px-2 py-1 rounded text-slate-400">Top 5</span>
      </h2>
      <div class="space-y-3">
        <% if (stats.topUsers && stats.topUsers.length > 0) { %>
          <% stats.topUsers.forEach((u, i) => { %>
            <div class="flex items-center justify-between p-3 bg-dark-800/50 rounded-lg hover:bg-dark-800 transition">
              <div class="flex items-center gap-3 flex-1">
                <span class="text-amber-400 font-bold text-lg"><%= i + 1 %></span>
                <div>
                  <div class="font-medium text-slate-200"><%= u.username %></div>
                  <div class="text-xs text-slate-400">Nivel <strong><%= u.level %></strong></div>
                </div>
              </div>
              <div class="text-right text-sm">
                <div class="text-emerald-400 font-mono"><%= u.balance.toLocaleString('es-ES') %></div>
                <div class="text-xs text-slate-400">saldo</div>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="text-slate-400 text-sm text-center py-6">Sin usuarios aún</div>
        <% } %>
      </div>
    </div>

    <!-- Módulos habilitados -->
    <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
      <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
        <span>🔌 Módulos Activos</span>
        <span class="text-xs bg-dark-800 px-2 py-1 rounded text-slate-400"><%= modules.filter(m => m.enabled).length %>/<%= modules.length %></span>
      </h2>
      <div class="space-y-2">
        <%
          const enabled = modules.filter(m => m.enabled);
          const disabled = modules.filter(m => !m.enabled);
        %>
        <% if (enabled.length > 0) { %>
          <div class="text-xs text-emerald-400 font-semibold mb-3">✅ Habilitados</div>
          <div class="flex flex-wrap gap-2 mb-4">
            <% enabled.forEach(m => { %>
              <span class="text-xs bg-emerald-500/20 text-emerald-300 px-3 py-1 rounded-full border border-emerald-500/30">
                <%= m.name %>
              </span>
            <% }); %>
          </div>
        <% } %>
        <% if (disabled.length > 0) { %>
          <div class="text-xs text-slate-500 font-semibold mb-3">⭕ Deshabilitados</div>
          <div class="flex flex-wrap gap-2">
            <% disabled.slice(0, 5).forEach(m => { %>
              <span class="text-xs bg-dark-800 text-slate-400 px-3 py-1 rounded-full border border-dark-700">
                <%= m.name %>
              </span>
            <% }); %>
            <% if (disabled.length > 5) { %>
              <span class="text-xs text-slate-500">+<%= disabled.length - 5 %> más</span>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Acciones rápidas -->
  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-lg font-semibold mb-4">⚡ Acciones Rápidas</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
      <a href="/servers/<%= guild.id %>/panel/general" class="flex items-center gap-2 bg-dark-800 hover:bg-dark-700 rounded-lg px-4 py-3 transition text-slate-300 text-sm font-medium">
        <span>⚙️</span> Configuración
      </a>
      <a href="/servers/<%= guild.id %>/panel/moderation" class="flex items-center gap-2 bg-dark-800 hover:bg-dark-700 rounded-lg px-4 py-3 transition text-slate-300 text-sm font-medium">
        <span>🛡️</span> Moderación
      </a>
      <a href="/servers/<%= guild.id %>/panel/tickets" class="flex items-center gap-2 bg-dark-800 hover:bg-dark-700 rounded-lg px-4 py-3 transition text-slate-300 text-sm font-medium">
        <span>📋</span> Tickets
      </a>
      <a href="/servers/<%= guild.id %>/panel/logging" class="flex items-center gap-2 bg-dark-800 hover:bg-dark-700 rounded-lg px-4 py-3 transition text-slate-300 text-sm font-medium">
        <span>📊</span> Logs
      </a>
      <a href="/servers/<%= guild.id %>/panel/economy" class="flex items-center gap-2 bg-dark-800 hover:bg-dark-700 rounded-lg px-4 py-3 transition text-slate-300 text-sm font-medium">
        <span>💰</span> Economía
      </a>
      <a href="/servers/<%= guild.id %>/panel/leveling" class="flex items-center gap-2 bg-dark-800 hover:bg-dark-700 rounded-lg px-4 py-3 transition text-slate-300 text-sm font-medium">
        <span>📈</span> Niveles
      </a>
      <a href="/servers/<%= guild.id %>/panel/security" class="flex items-center gap-2 bg-dark-800 hover:bg-dark-700 rounded-lg px-4 py-3 transition text-slate-300 text-sm font-medium">
        <span>🔐</span> Seguridad
      </a>
      <a href="/servers/<%= guild.id %>/panel/confessions" class="flex items-center gap-2 bg-dark-800 hover:bg-dark-700 rounded-lg px-4 py-3 transition text-slate-300 text-sm font-medium">
        <span>💬</span> Confesiones
      </a>
    </div>
  </div>

  <!-- Tips para admins -->
  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-lg font-semibold mb-4">💡 Tips para Administradores</h2>
    <div class="space-y-3 text-sm text-slate-300">
      <div class="flex gap-3">
        <span class="text-amber-400">1.</span>
        <span>Habilita los módulos que necesites desde <strong>Configuración General</strong>.</span>
      </div>
      <div class="flex gap-3">
        <span class="text-amber-400">2.</span>
        <span>Configura canales de bienvenida, logs y tickets para mejor experiencia de staff.</span>
      </div>
      <div class="flex gap-3">
        <span class="text-amber-400">3.</span>
        <span>El sistema de niveles y economía se actualizan en tiempo real según la actividad.</span>
      </div>
      <div class="flex gap-3">
        <span class="text-amber-400">4.</span>
        <span>Los tickets abiertos se cierran automáticamente tras <strong>48 horas</strong> de inactividad.</span>
      </div>
      <div class="flex gap-3">
        <span class="text-amber-400">5.</span>
        <span>Usa <strong>/god logs</strong> en Discord para ver eventos del bot en tiempo real.</span>
      </div>
    </div>
  </div>
</div>
