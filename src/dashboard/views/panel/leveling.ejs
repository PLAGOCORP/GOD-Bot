<div class="space-y-6 max-w-4xl">
  <div class="dash-hero">
    <div class="relative z-10">
      <p class="text-amber-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Progresión</p>
      <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">📈 Niveles</h1>
      <p class="text-slate-500 text-sm">XP por mensajes y voz, cooldowns y canal de level-up.</p>
    </div>
  </div>

  <div class="dash-card p-6">
    <form id="levelingForm" class="space-y-5">
      <label class="flex items-center gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 cursor-pointer">
        <input type="checkbox" name="leveling_enabled" <%= modules.find(m=>m.name==='leveling')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="font-semibold text-slate-200">Activar Niveles</span>
      </label>
      <div class="grid sm:grid-cols-2 gap-4">
        <div><label class="block text-xs text-slate-500 mb-1.5">Canal level-up</label><%- channelSelect('levelChannel', settings.levelChannel) %></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">XP mínimo</label><input type="number" name="xpMin" value="<%= settings.xpMin || 15 %>" class="servers-search w-full" style="padding-left:1rem"/></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">XP máximo</label><input type="number" name="xpMax" value="<%= settings.xpMax || 25 %>" class="servers-search w-full" style="padding-left:1rem"/></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">Cooldown (ms)</label><input type="number" name="cooldown" value="<%= settings.cooldown || 60000 %>" class="servers-search w-full" style="padding-left:1rem"/></div>
        <div><label class="block text-xs text-slate-500 mb-1.5">XP voz / minuto</label><input type="number" name="voiceXpPerMinute" value="<%= settings.voiceXpPerMinute || 5 %>" class="servers-search w-full" style="padding-left:1rem"/></div>
      </div>
      <button type="submit" class="dash-btn-primary">Guardar</button>
    </form>
  </div>
</div>

<script>
document.getElementById('levelingForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    levelChannel: fd.get('levelChannel') || null,
    xpMin: parseInt(fd.get('xpMin'), 10) || 15,
    xpMax: parseInt(fd.get('xpMax'), 10) || 25,
    cooldown: parseInt(fd.get('cooldown'), 10) || 60000,
    voiceXpPerMinute: parseInt(fd.get('voiceXpPerMinute'), 10) || 5,
  });
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { leveling: fd.get('leveling_enabled') === 'on' } });
});
</script>