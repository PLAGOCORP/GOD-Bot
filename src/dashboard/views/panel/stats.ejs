<div class="max-w-3xl space-y-6">
  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-xl font-semibold mb-4">Stats</h2>
    <form id="statsForm" class="space-y-4">
      <label class="flex items-center gap-3">
        <input type="checkbox" name="stats_enabled" <%= modules.find(m=>m.name==='stats')?.enabled ? 'checked' : '' %> class="rounded accent-amber-400"/>
        <span class="font-medium">Activar Stats</span>
      </label>

      <div class="grid sm:grid-cols-3 gap-4 mt-4">
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Canal Miembros</label>
          <%- channelSelect('statsChannels.members', settings.statsChannels?.members) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Canal En línea</label>
          <%- channelSelect('statsChannels.online', settings.statsChannels?.online) %>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Canal Boosts</label>
          <%- channelSelect('statsChannels.boosts', settings.statsChannels?.boosts) %>
        </div>
      </div>

      <button type="submit" class="mt-4 bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2 rounded-lg">Guardar</button>
    </form>
  </div>
</div>

<script>
document.getElementById('statsForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/settings', {
    statsChannels: {
      members: fd.get('statsChannels.members') || null,
      online: fd.get('statsChannels.online') || null,
      boosts: fd.get('statsChannels.boosts') || null,
    },
  });
  const mod = fd.get('stats_enabled') === 'on';
  await saveSettings('/api/guilds/<%= guild.id %>/modules', { modules: { stats: mod } });
});
</script>