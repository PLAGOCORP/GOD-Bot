<div class="space-y-6 max-w-4xl">
  <div class="dash-hero">
    <div class="relative z-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <p class="text-amber-400/80 text-xs font-bold tracking-[0.2em] uppercase mb-2">Respuestas</p>
        <h1 class="text-2xl sm:text-3xl font-black text-white mb-1">🏷️ Tags</h1>
        <p class="text-slate-500 text-sm">Textos predefinidos invocados con <code class="text-amber-400/80">/tag</code>.</p>
      </div>
      <div class="dash-stat-card stat-amber self-start sm:self-center" style="padding:0.85rem 1.1rem">
        <div class="text-slate-500 text-xs uppercase font-semibold">Total</div>
        <div class="text-2xl font-black text-amber-400"><%= (tags || []).length %></div>
      </div>
    </div>
  </div>

  <div class="dash-card overflow-hidden">
    <div class="p-5 border-b border-white/5">
      <h2 class="text-sm font-bold text-slate-300">Tags existentes</h2>
    </div>
    <% if (tags && tags.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/5 text-left">
              <th class="px-4 py-3 text-slate-500 text-xs uppercase">Nombre</th>
              <th class="px-4 py-3 text-slate-500 text-xs uppercase">Contenido</th>
              <th class="px-4 py-3 text-slate-500 text-xs uppercase">Usos</th>
              <th class="px-4 py-3 text-slate-500 text-xs uppercase">Acción</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <% tags.forEach(function(tag) { %>
              <tr class="hover:bg-white/[0.02] transition">
                <td class="px-4 py-3 font-mono text-amber-400"><%= tag.name %></td>
                <td class="px-4 py-3 text-slate-400 truncate max-w-[240px]"><%= tag.content %></td>
                <td class="px-4 py-3 text-slate-500"><%= tag.uses || 0 %></td>
                <td class="px-4 py-3">
                  <button type="button" onclick="deleteTag('<%= tag.name %>')" class="text-xs px-2 py-1 rounded bg-red-500/10 text-red-300 hover:bg-red-500/20 transition">Eliminar</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="px-5 py-10 text-center text-slate-500 text-sm">No hay tags creados aún.</p>
    <% } %>
  </div>

  <div class="dash-card p-6">
    <h2 class="text-sm font-bold text-slate-300 mb-4">Crear tag</h2>
    <form id="tagForm" class="space-y-4">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs text-slate-500 mb-1.5">Nombre</label>
          <input type="text" name="tagName" required class="servers-search w-full font-mono" style="padding-left:1rem" placeholder="mi-tag"/>
        </div>
        <div>
          <label class="block text-xs text-slate-500 mb-1.5">Contenido</label>
          <input type="text" name="tagContent" required class="servers-search w-full" style="padding-left:1rem" placeholder="Texto del tag"/>
        </div>
      </div>
      <button type="submit" class="dash-btn-primary">Crear tag</button>
    </form>
  </div>
</div>

<script>
document.getElementById('tagForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/tags', { action: 'add', name: fd.get('tagName'), content: fd.get('tagContent') });
  location.reload();
});
async function deleteTag(name) {
  if (!confirm('¿Eliminar el tag "' + name + '"?')) return;
  await saveSettings('/api/guilds/<%= guild.id %>/tags', { action: 'delete', name });
  location.reload();
}
</script>