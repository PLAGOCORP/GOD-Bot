<div class="max-w-3xl space-y-6">
  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-xl font-semibold mb-4">Tags Existentes</h2>
    <% if (tags && tags.length > 0) { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-slate-400 border-b border-dark-700">
              <th class="pb-2 pr-4">Nombre</th>
              <th class="pb-2 pr-4">Contenido</th>
              <th class="pb-2 pr-4">Usos</th>
              <th class="pb-2">Acción</th>
            </tr>
          </thead>
          <tbody>
            <% tags.forEach(function(tag) { %>
              <tr class="border-b border-dark-800 hover:bg-dark-800/50">
                <td class="py-2 pr-4 font-mono text-amber-400"><%= tag.name %></td>
                <td class="py-2 pr-4 text-slate-300 truncate max-w-[200px]"><%= tag.content %></td>
                <td class="py-2 pr-4 text-slate-400"><%= tag.uses || 0 %></td>
                <td class="py-2">
                  <button type="button" onclick="deleteTag('<%= tag.name %>')" class="text-red-400 hover:text-red-300 text-xs">Eliminar</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="text-slate-500 text-sm">No hay tags creados aún.</p>
    <% } %>
  </div>

  <div class="bg-dark-900 border border-dark-700 rounded-xl p-6">
    <h2 class="text-xl font-semibold mb-4">Crear Tag</h2>
    <form id="tagForm" class="space-y-4">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Nombre</label>
          <input type="text" name="tagName" required class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full" placeholder="mi-tag"/>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-400 mb-1">Contenido</label>
          <input type="text" name="tagContent" required class="bg-dark-800 border border-dark-700 rounded-lg px-3 py-2 w-full" placeholder="Contenido del tag"/>
        </div>
      </div>
      <button type="submit" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-semibold px-5 py-2 rounded-lg">Crear Tag</button>
    </form>
  </div>
</div>

<script>
document.getElementById('tagForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(e.target);
  await saveSettings('/api/guilds/<%= guild.id %>/tags', {
    action: 'add',
    name: fd.get('tagName'),
    content: fd.get('tagContent'),
  });
  location.reload();
});

async function deleteTag(name) {
  if (!confirm('¿Eliminar el tag "' + name + '"?')) return;
  await saveSettings('/api/guilds/<%= guild.id %>/tags', {
    action: 'delete',
    name,
  });
  location.reload();
}
</script>