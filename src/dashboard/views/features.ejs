<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Features — botgod.pro</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen">
  <%- include('partials/nav') %>
  <main class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold mb-2">Features</h1>
    <p class="text-slate-400 mb-10">Todo lo que incluye God Bot en botgod.pro</p>
    <div class="space-y-4 text-slate-300">
      <% [
        ['Moderación + AutoMod', '/moderacion, /automod, escalation, sticky roles, bulk roles'],
        ['Tickets pro', 'Panel, modal, claim, transcript HTML, CSAT'],
        ['Niveles', 'XP texto/voz, rewards, no-XP, multiplicadores, rank card'],
        ['Giveaways', 'Botón participar, requisitos, reroll, DM ganadores'],
        ['Roles', 'Reacción, botón, select menu, autorole, sticky, masivo'],
        ['Música', '@discordjs/voice + play-dl + ffmpeg'],
        ['NQN', ':emoji: vía webhook + /emote robar'],
        ['Starboard / Cumpleaños / Temp VC', 'Engagement completo'],
        ['IA', '/god preguntar y /god resumir (Grok/xAI)'],
        ['Plantillas', 'Gaming, Support, Educación… crean canales y roles'],
        ['Seguridad', 'Anti-nuke, anti-raid, quiz verificación'],
        ['Dashboard web', 'OAuth2 Discord en https://botgod.pro'],
        ['Economía, invites, tags, polls, memes…', 'Y mucho más'],
      ].forEach(function(row) { %>
        <div class="border border-slate-800 rounded-xl p-5 bg-slate-900/50">
          <div class="font-semibold text-amber-400"><%= row[0] %></div>
          <div class="text-sm text-slate-400 mt-1"><%= row[1] %></div>
        </div>
      <% }) %>
    </div>
    <div class="mt-10 flex gap-4">
      <a href="<%= inviteUrl %>" class="bg-amber-400 text-slate-950 font-bold px-6 py-3 rounded-xl">Invitar</a>
      <a href="/login" class="bg-indigo-600 text-white font-semibold px-6 py-3 rounded-xl">Dashboard</a>
    </div>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
