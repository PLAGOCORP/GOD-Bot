{
  "hosting": {
    "public": "web/public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      },
      {
        "source": "**/*.@(js|css|png|jpg|svg|webp)",
        "headers": [
          { "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }
        ]
      }
    ],
    "redirects": [
      { "source": "/login", "destination": "https://panel.botgod.pro/login", "type": 302 },
      { "source": "/logout", "destination": "https://panel.botgod.pro/logout", "type": 302 },
      { "source": "/auth/callback", "destination": "https://panel.botgod.pro/auth/callback", "type": 302 },
      { "source": "/servers", "destination": "https://panel.botgod.pro/servers", "type": 302 },
      { "source": "/servers/**", "destination": "https://panel.botgod.pro/servers/:splat", "type": 302 },
      { "source": "/status", "destination": "https://panel.botgod.pro/status", "type": 302 },
      { "source": "/health", "destination": "https://panel.botgod.pro/health", "type": 302 },
      { "source": "/features", "destination": "https://panel.botgod.pro/features", "type": 302 },
      { "source": "/api/**", "destination": "https://panel.botgod.pro/api/:splat", "type": 302 }
    ],
    "rewrites": []
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
